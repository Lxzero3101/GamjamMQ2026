  m_Script: {fileID: 11500000, guid: ea1c59ace054e0f4cb9e17e1e77a9b89, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  dialogueBox: {fileID: 411166933}
  textComponent: {fileID: 103736809}
  lines:
  - The sunlight left the arena floor.
  - But the Warrior himself, went still.
  - "Not like a statue \u2014 like a person who has finished what they came to do
    and let themselves rest. There was a difference, and Nesia felt it."
  - "Not like a statue \u2014 like a person who has finished what they came to do
    and let themselves rest. There was a difference, and Nesia can feel it. "
  - Holding a bittersweet feeling, she walked into the corridor beyond.
  textSpeed: 0.05
  playerTag: Player
  triggerOnce: 1
